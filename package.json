{
  "name": "tuclip",
  "productName": "TuClip",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:1420 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:1420 electron .",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@fontsource/manrope": "^5.2.8",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@tesseract.js-data/chi_sim": "^1.0.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "electron-liquid-glass": "^1.1.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.2.3",
    "tesseract.js": "^7.0.0",
    "use-image": "^1.1.4",
    "webdav": "^5.9.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
